# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
# For development, you can leave this blank and a default will be used (not secure!)
# For production, ALWAYS generate a secure secret
NEXTAUTH_SECRET=your-secret-key-here

# OAuth Provider - Google (REQUIRED)
# Get from: https://console.cloud.google.com
GOOGLE_ID=your-google-client-id
GOOGLE_SECRET=your-google-client-secret

# OAuth Provider - GitHub (Optional)
# Get from: https://github.com/settings/developers
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Optional: Email whitelist for admin access (comma-separated)
# Only these emails can access the admin panel
# AUTHORIZED_EMAILS=admin@example.com,trusted@example.com
